# ==================== ZALO OA CONFIGURATION ====================
ZALO_WEBHOOK_TOKEN=your_secure_webhook_token_here
ZALO_OA_ID=your_zalo_oa_id
ZALO_ACCESS_TOKEN=your_zalo_access_token

# ==================== LLM PROVIDER SELECTION ====================
# Options: ollama, groq, huggingface, cohere
LLM_PROVIDER=ollama

# ==================== OLLAMA (Local, Completely Free) ====================
# Download from: https://ollama.ai
# Run: ollama run mistral
OLLAMA_BASE_URL=http://localhost:11434

# ==================== GROQ API (Free Tier) ====================
# Sign up at: https://console.groq.com
# Get API key from dashboard
GROQ_API_KEY=your_groq_api_key

# ==================== HUGGINGFACE API (Free Tier) ====================
# Sign up at: https://huggingface.co
# Create token in Settings > Access Tokens
HUGGINGFACE_API_KEY=your_huggingface_api_key

# ==================== COHERE API (Free Tier) ====================
# Sign up at: https://cohere.ai
# Get API key from dashboard
COHERE_API_KEY=your_cohere_api_key

# ==================== SERVER CONFIGURATION ====================
PORT=3000
NODE_ENV=development
